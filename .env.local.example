# Copia este archivo a .env.local y pon tu propia API key de Anthropic.
# .env.local está ignorado por git (no se sube al repo).
#
# El mejorador de prompts de /beta usa esta key para llamar a Claude EN LOCAL.
# Consíguela en: https://console.anthropic.com/  (sección API Keys)
#
# ⚠️ Solo para desarrollo local: al usar NEXT_PUBLIC_ la key queda en el bundle.
#    Para publicar /beta en producción, migraremos a un proxy PHP (la key no se expone).

NEXT_PUBLIC_ANTHROPIC_API_KEY=sk-ant-tu-key-aqui

# Opcional: modelo a usar (por defecto claude-haiku-4-5-20251001, rápido y económico).
# Alternativa de mayor calidad: claude-sonnet-5
NEXT_PUBLIC_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
