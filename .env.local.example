# Copia este archivo a .env.local (para local) y pon tu API key de OpenAI.
# .env.local está ignorado por git (no se sube al repo).
#
# En Vercel: agrega OPENAI_API_KEY en Settings → Environment Variables.
# La key vive SOLO en el servidor (no lleva NEXT_PUBLIC), nunca llega al navegador.
#
# Consíguela en: https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-tu-key-de-openai-aqui

# Opcional: modelo (por defecto gpt-4o-mini, rápido y económico).
# Alternativas: gpt-4o, gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini
